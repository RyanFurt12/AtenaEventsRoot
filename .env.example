# ╔══════════════════════════════════════════════════════════════════════════════╗
# ║  AtenaEvents – Variáveis de Ambiente                                       ║
# ║  Copie este arquivo para .env e preencha todos os valores.                 ║
# ╚══════════════════════════════════════════════════════════════════════════════╝

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=atena_events
POSTGRES_USER=atena
POSTGRES_PASSWORD=TROQUE_PARA_UMA_SENHA_FORTE

# ─── Spring Boot API ─────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod

# Chave secreta para assinar os tokens JWT (mínimo 32 caracteres).
# Gere uma com: openssl rand -base64 48
JWT_SECRET=TROQUE_PARA_UMA_CHAVE_SECRETA_FORTE_MIN_32_CHARS

# ─── URLs ─────────────────────────────────────────────────────────────────────
# URL pública da API — usada pelo frontend (bundle Vite) e pela API (redirect OAuth)
API_URL=http://localhost:8080
# URL pública do frontend — usada pela API para redirects OAuth e CORS
FRONTEND_URL=http://localhost:3000

# ─── OAuth2 ──────────────────────────────────────────────────────────────────
# Redirect URIs a autorizar nos consoles:
#   Google → {API_URL}/login/oauth2/code/google
#   GitHub → {API_URL}/login/oauth2/code/github
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-secret

# ─── SMTP ─────────────────────────────────────────────────────────────────────
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=your-smtp-login@example.com
MAIL_PASSWORD=your-smtp-password
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true
MAIL_FROM=no-reply@seu-dominio.com
